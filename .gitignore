# IDE folders and files
.idea

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/
.env
test-debug.env
.env.bak
scripts/containergroup.yaml
*.junit.xml
# Squad: ignore runtime state (logs, inbox, sessions)
# Note: .squad/casting/* is identity and MUST be committed to main, not ignored
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: state owned by squad-state branch (two-layer/orphan backend)
.squad/decisions.md
.squad/agents/*/history.md
# /Squad: state owned by squad-state branch
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
